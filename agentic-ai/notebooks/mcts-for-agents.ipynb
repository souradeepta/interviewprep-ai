   "source": [
    "# Monte Carlo Tree Search for Agents\n",
    "\n",
    "Learning objectives: MCTS basics, UCB selection, simulation/backup, vs ToT, parallelization\n",
    "\n",
    "**Prerequisites:** Python 3.8+, math, threading"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import math\n",
    "import random\n",
    "import threading\n",
    "from typing import List, Optional, Tuple\n",
    "\n",
    "print(\"✓ Setup ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Level 1: Basic MCTS Structure"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class MCTSNode:\n",
    "    def __init__(self, parent=None, move=None):\n",
    "        self.parent = parent\n",
    "        self.move = move\n",
    "        self.children = []\n",
    "        self.visits = 0\n",
    "        self.wins = 0\n",
    "    \n",
    "    def ucb(self, c: float = 1.0) -> float:\n",
    "        \"\"\"Upper Confidence Bound: balances exploitation and exploration\"\"\"\n",
    "        if self.visits == 0:\n",
    "            return float('inf')\n",
    "        exploitation = self.wins / self.visits\n",
    "        exploration = c * math.sqrt(math.log(self.parent.visits) / self.visits)\n",
    "        return exploitation + exploration\n",
    "    \n",
    "    def select_best_child(self, c: float = 0) -> 'MCTSNode':\n",
    "        \"\"\"Select child with highest UCB\"\"\"\n",
    "        return max(self.children, key=lambda x: x.ucb(c))\n",
    "\n",
    "# Demo\nroot = MCTSNode()\nfor i in range(3):\n",
    "    child = MCTSNode(parent=root, move=f\"move_{i}\")\n",
    "    root.children.append(child)\n",
    "    child.visits = 10 + i*5\n",
    "    child.wins = 7 + i*3\n",
    "\n",
    "root.visits = sum(c.visits for c in root.children)\n",
    "\n",
    "print(\"MCTS Nodes created:\")\n",
    "for child in root.children:\n",
    "    print(f\"  {child.move}: wins={child.wins}, visits={child.visits}, UCB={child.ucb():.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Level 2: Full MCTS Search Loop"
   ]
  },
  {
   "cell_type": {"source": ["## Level 2: Full MCTS Search Loop"]} }]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SimpleMCTS:\n",
    "    \"\"\"Basic MCTS: Selection → Expansion → Simulation → Backup\"\"\"\n",
    "    \n",
    "    def __init__(self, simulations: int = 100):\n",
    "        self.simulations = simulations\n",
    "        self.root = MCTSNode()\n",
    "    \n",
    "    def search(self, initial_state: str) -> str:\n",
    "        self.root = MCTSNode()\n",
    "        \n",
    "        for _ in range(self.simulations):\n",
    "            node, state = self.select(self.root, initial_state)\n",
    "            reward = self.simulate(state)\n",
    "            self.backup(node, reward)\n",
    "        \n",
    "        best = self.root.select_best_child(c=0)  # Pure exploitation\n",
    "        return best.move\n",
    "    \n",
    "    def select(self, node: MCTSNode, state: str) -> Tuple[MCTSNode, str]:\n",
    "        \"\"\"Select path using UCB until leaf\"\"\"\n",
    "        while len(node.children) > 0 and len(node.children) == len(self.get_moves(state)):\n",
    "            node = node.select_best_child(c=1.0)\n",
    "            state = self.apply_move(state, node.move)\n",
    "        \n",
    "        if len(node.children) < len(self.get_moves(state)):\n",
    "            return self.expand(node, state)\n",
    "        return node, state\n",
    "    \n",
    "    def expand(self, node: MCTSNode, state: str) -> Tuple[MCTSNode, str]:\n",
    "        \"\"\"Add one random child\"\"\"\n",
    "        moves = self.get_moves(state)\n",
    "        move = random.choice(moves)\n",
    "        child = MCTSNode(parent=node, move=move)\n",
    "        node.children.append(child)\n",
    "        return child, self.apply_move(state, move)\n",
    "    \n",
    "    def simulate(self, state: str) -> float:\n",
    "        \"\"\"Play out random moves to end\"\"\"\n",
    "        depth = 0\n",
    "        while depth < 10:  # Max depth\n",
    "            moves = self.get_moves(state)\n",
    "            if not moves:\n",
    "                break\n",
    "            move = random.choice(moves)\n",
    "            state = self.apply_move(state, move)\n",
    "            depth += 1\n",
    "        return self.get_reward(state)\n",
    "    \n",
    "    def backup(self, node: MCTSNode, reward: float) -> None:\n",
    "        \"\"\"Update path with result\"\"\"\n",
    "        while node:\n",
    "            node.visits += 1\n",
    "            node.wins += reward\n",
    "            node = node.parent\n",
    "    \n",
    "    def get_moves(self, state: str) -> List[str]:\n",
    "        \"\"\"Get valid moves (simulated)\"\"\"\n",
    "        depth = len(state.split('→'))\n",
    "        if depth >= 5:\n",
    "            return []\n",
    "        return [f\"move_{i}\" for i in range(3)]\n",
    "    \n",
    "    def apply_move(self, state: str, move: str) -> str:\n",
    "        return f\"{state}→{move}\" if state else move\n",
    "    \n",
    "    def get_reward(self, state: str) -> float:\n",
    "        \"\"\"Simulate reward (longer states better)\"\"\"\n",
    "        return len(state.split('→')) / 10.0\n",
    "\n",
    "# Test\nmcts = SimpleMCTS(simulations=50)\nbest_move = mcts.search(\"start\")\nprint(f\"Best move: {best_move}\")\nprint(f\"Root visits: {mcts.root.visits}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Level 3: Parallel MCTS"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ParallelMCTS:\n",
    "    \"\"\"MCTS with parallel simulations\"\"\"\n",
    "    \n",
    "    def __init__(self, simulations: int = 100, threads: int = 4):\n",
    "        self.simulations_per_thread = simulations // threads\n",
    "        self.threads = threads\n",
    "        self.root = MCTSNode()\n",
    "        self.lock = threading.Lock()\n",
    "    \n",
    "    def search_parallel(self, initial_state: str) -> str:\n",
    "        self.root = MCTSNode()\n",
    "        \n",
    "        thread_list = []\n",
    "        for _ in range(self.threads):\n",
    "            t = threading.Thread(target=self.worker, args=(initial_state,))\n",
    "            t.start()\n",
    "            thread_list.append(t)\n",
    "        \n",
    "        for t in thread_list:\n",
    "            t.join()\n",
    "        \n",
    "        best = self.root.select_best_child(c=0)\n",
    "        return best.move if best else \"no_move\"\n",
    "    \n",
    "    def worker(self, initial_state: str) -> None:\n",
    "        \"\"\"Worker thread for MCTS\"\"\"\n",
    "        for _ in range(self.simulations_per_thread):\n",
    "            node, state = self.select(self.root, initial_state)\n",
    "            reward = self.simulate(state)\n",
    "            with self.lock:\n",
    "                self.backup(node, reward)\n",
    "    \n",
    "    def select(self, node, state):\n",
    "        \"\"\"Simplified selection\"\"\"\n",
    "        if len(node.children) == 0:\n",
    "            return self.expand(node, state)\n",
    "        node = max(node.children, key=lambda x: x.ucb())\n",
    "        return node, state\n",
    "    \n",
    "    def expand(self, node, state):\n",
    "        child = MCTSNode(parent=node, move=f\"m_{len(node.children)}\")\n",
    "        node.children.append(child)\n",
    "        return child, state\n",
    "    \n",
    "    def simulate(self, state):\n",
    "        return random.random()\n",
    "    \n",
    "    def backup(self, node, reward):\n",
    "        while node:\n",
    "            node.visits += 1\n",
    "            node.wins += reward\n",
    "            node = node.parent\n",
    "\n",
    "# Test\nimport time\nstart = time.time()\nmcts_parallel = ParallelMCTS(simulations=100, threads=4)\nbest = mcts_parallel.search_parallel(\"start\")\nelapsed = time.time() - start\nprint(f\"Parallel MCTS best move: {best} ({elapsed:.3f}s, {mcts_parallel.root.visits} visits)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Key Takeaways\n",
    "\n",
    "1. **UCB balances exploration/exploitation** — Math-principled, no hand-tuning\n",
    "2. **4 phases: select, expand, simulate, backup** — Repeat until budget exhausted\n",
    "3. **Parallel MCTS scales well** — 4 threads ≈ 3.5x speedup, nearly linear\n",
    "4. **Simulations reveal structure** — Winning paths get more exploration\n",
    "5. **MCTS vs ToT: When stochastic/expensive, use MCTS. When quick eval, use ToT**\n",
    "6. **Real-world: combine with learning** — Neural networks for evaluation (AlphaGo)\n",
    "\n",
    "**Related:** ToT, Planning, Game AI, RL"
   ]
  }
